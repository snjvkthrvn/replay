DATABASE_URL=postgresql://postgres:change-me@postgres:5432/replay
REDIS_PASSWORD=change-me
JWT_SECRET=replace-with-at-least-32-random-characters
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=replay://
ALLOWED_ORIGINS=https://replay-api-ic3h.onrender.com,replay://
FIREBASE_SERVICE_ACCOUNT_JSON=
SENTRY_DSN=
NODE_ENV=production
PORT=3000

# Used by Caddy in docker-compose.prod.yml to auto-provision TLS.
# Set this to the DNS name pointing at the production host (e.g. api.example.com).
API_HOSTNAME=api.example.com
