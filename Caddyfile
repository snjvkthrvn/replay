{$API_HOSTNAME} {
	# Proxy HTTP + WebSocket traffic to the API container.
	# Caddy auto-detects WebSocket upgrades; no extra config needed.
	reverse_proxy api:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	# Sensible security headers for an API serving a mobile client.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}

	# Compress responses where it helps.
	encode gzip zstd

	# Reasonable request log; ship to stdout so Docker captures it.
	log {
		output stdout
		format json
	}
}
